# ------------------------------------------------------------------
# Modèle de configuration — copier vers .env.local et remplir.
# .env.local n'est JAMAIS commité (voir .gitignore). Ne mets pas de
# secrets dans ce fichier .env.example : il est versionné.
# ------------------------------------------------------------------

# YouTube Data API v3
# Clé : https://console.cloud.google.com (activer "YouTube Data API v3")
# Channel ID : https://www.youtube.com/account_advanced
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# GitHub — API publique, pas de clé nécessaire, juste le pseudo
GITHUB_USERNAME=

# Replis manuels (facultatif) : nombre d'abonnés affiché quand aucune API
# officielle n'est disponible (Instagram, TikTok, LinkedIn) ou en secours.
# Mettre à jour à la main, ou brancher un service tiers (RapidAPI) plus tard.
SOCIAL_INSTAGRAM_FOLLOWERS=
SOCIAL_TIKTOK_FOLLOWERS=
SOCIAL_LINKEDIN_FOLLOWERS=
SOCIAL_YOUTUBE_FOLLOWERS=
SOCIAL_GITHUB_FOLLOWERS=
